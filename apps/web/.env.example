# Database
# SQLite for dev. Swap to a Postgres URL for production (also change provider in prisma/schema.prisma).
DATABASE_URL="file:./dev.db"

# Auth.js v5
# Generate with: openssl rand -hex 32
AUTH_SECRET="replace-with-openssl-rand-hex-32"

# Public base URL. Set automatically by .devcontainer/setup.sh in Codespaces.
AUTH_URL="http://localhost:3000"

# Required when running behind a proxy (Codespaces, Vercel, Render, etc.)
AUTH_TRUST_HOST="true"

# --- Phase 2 connectors (not used yet; leave blank or remove until wired up) ---
# QB_CLIENT_ID=
# QB_CLIENT_SECRET=
# QB_REDIRECT_URI=
# RESEND_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=

# --- Object storage for documents (S3-compatible: AWS S3 or Cloudflare R2) ---
# Leave unset to fall back to local-disk storage (public/uploads) in dev.
# STORAGE_ENDPOINT is only needed for R2/MinIO/etc. (omit for plain AWS S3).
# For R2 the endpoint looks like https://<accountid>.r2.cloudflarestorage.com
# STORAGE_ENDPOINT=
# STORAGE_REGION="auto"
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=

# External API key for Henley Tasks projects feed (Door 1)
HUB_TASKS_API_KEY=""


# Henley Tasks push integration (Hub → tasks.henleycontracting.com)
# apiKey is stored in the DB (HenleyTasksConfig singleton) — these env vars are
# fallback-only for fresh installs. Never put real keys here or in source control.
HENLEY_TASKS_API_KEY=
HENLEY_TASKS_API_URL=

# Microsoft 365 shared-mailbox sync (app registration by IT)
M365_TENANT_ID=""
M365_CLIENT_ID=""
M365_CLIENT_SECRET=""
M365_MAILBOX=""
