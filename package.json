{
  "name": "henley-hub",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "db:push": "npm run db:push -w @repo/db",
    "db:generate": "npm run db:generate -w @repo/db",
    "db:seed": "npm run db:seed -w @repo/db",
    "db:reset": "npm run db:reset -w @repo/db"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  }
}
