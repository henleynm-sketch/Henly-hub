generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite has no enums; role/status fields are validated in code (see src/lib/roles.ts).

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  passwordHash String
  role        String   // CEO | OFFICE | FIELD | SUB | CLIENT
  focusArea   String?  // e.g. "Sales", "Production", "Design"
  phone       String?
  avatarUrl   String?
  clientId    String?  // if role=CLIENT, link to the Client record they own
  client      Client?  @relation("ClientUsers", fields: [clientId], references: [id])
  qbEmployeeId String?
  department  String?
  reportsToId String?
  reportsTo   User?    @relation("ReportsTo", fields: [reportsToId], references: [id])
  reports     User[]   @relation("ReportsTo")
  active      Boolean  @default(true)
  notificationPrefs UserNotificationPref[]
  assignedProjects ProjectAssignment[]
  authoredLogs DailyLog[]
  authoredMessages Message[] @relation("AuthoredMessages")
  createdEstimates Estimate[] @relation("EstimateAuthor")
  timeEntries TimeEntry[]
  approvedTimeEntries TimeEntry[] @relation("TimeEntryApprover")
  uploadedDocuments Document[] @relation("UploadedDocuments")
  authoredContracts Contract[] @relation("ContractAuthor")
  createdChangeOrders ChangeOrder[] @relation("ChangeOrderAuthor")
  createdApiKeys ApiKey[]      @relation("ApiKeyCreator")
  apiKeyAudits   ApiKeyAudit[] @relation("ApiKeyAudit")
  scheduleTasks  ScheduleTask[] @relation("ScheduleTaskAssignee")
  crmActivities  CrmActivity[] @relation("CrmActivityAuthor")
  createdAt   DateTime @default(now())
}

model Client {
  id           String    @id @default(cuid())
  name         String
  primaryEmail String?
  primaryPhone String?
  address      String?
  city         String?
  state        String?
  zip          String?
  stage        String    @default("LEAD") // LEAD | QUALIFIED | PROPOSAL | WON | LOST | ACTIVE | PAST
  source       String?
  leadSource   String?    // see LEAD_SOURCE in src/lib/taxonomy.ts
  notes        String?
  qbCustomerId String?
  users        User[]    @relation("ClientUsers")
  projects     Project[]
  threads      Thread[]
  estimates    Estimate[]
  contracts    Contract[]
  crmActivities CrmActivity[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Project {
  id           String    @id @default(cuid())
  clientId     String
  client       Client    @relation(fields: [clientId], references: [id])
  name         String
  code         String?   @unique  // short join key (e.g. "SMTH") for per-project Tasks; unique among non-null
  address      String?
  city         String?
  projectType  String?   // Custom Home | Addition | Renovation | Kitchen | Garage | ADU | Misc Small Jobs | Handyman Services | Warranty
  status       String    @default("OPEN") // CLOSED | GENERAL | OPEN | PRESALE | WARRANTY -- see isValidJobStatus in src/lib/taxonomy.ts
  currentPhase String?   // free-text operational phase (e.g. "Permitting / Design Refresh", "Finishings 80%")
  nextStep     String?   // free-text next-action description from the operational tracker
  team         String?   // comma-separated names of PMs / owners (free-text)
  startDate    DateTime?
  actualStart  DateTime?
  targetEnd    DateTime?
  actualEnd    DateTime?
  budgetCents  Int       @default(0)
  contractCents Int      @default(0)
  description  String?
  archivedAt   DateTime?  // set by the v1 API archive endpoint; never hard-deletes
  jobType           String?    // see JOB_TYPE in src/lib/taxonomy.ts
  pipelineStage     String?    // see PIPELINE_STAGE in src/lib/taxonomy.ts
  constructionPhase String?    // see CONSTRUCTION_PHASE in src/lib/taxonomy.ts
  warrantyPhase     String?    // see WARRANTY_PHASE in src/lib/taxonomy.ts
  division          String?    // see DIVISION in src/lib/taxonomy.ts
  projectManager    String?    // PM name (free-text; FK to User planned for later)
  salesRep          String?    // sales rep name
  customerPO        String?    // customer PO / reference number
  scheduleTasks ScheduleTask[]
  milestones   Milestone[]
  dailyLogs    DailyLog[]
  budgetItems  BudgetItem[]
  documents    Document[]
  threads      Thread[]
  selections   Selection[]
  assignments  ProjectAssignment[]
  timeEntries  TimeEntry[]
  contracts    Contract[]
  crmActivities CrmActivity[]
  changeOrders ChangeOrder[]
  warrantyItems WarrantyItem[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ProjectAssignment {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   // PM | LEAD | CREW | SUB | DESIGNER
  project   Project  @relation(fields: [projectId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  @@unique([projectId, userId])
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  title       String
  description String?
  dueDate     DateTime?
  status      String    @default("PENDING") // PENDING | IN_PROGRESS | DONE | BLOCKED
  clientVisible Boolean @default(true)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
}

model Selection {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  category    String   // e.g. "Cabinets", "Flooring"
  option      String
  priceCents  Int      @default(0)
  status      String   @default("PROPOSED") // PROPOSED | APPROVED | REJECTED
  decidedAt   DateTime?
  notes       String?
}

model BudgetItem {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id])
  category         String   // Demo, Framing, Plumbing, etc.
  description      String
  estimateCents    Int      @default(0)
  actualCents      Int      @default(0)
  vendor           String?
  sourceTemplateId String?  // set when created from a template (idempotency)
  createdAt        DateTime @default(now())
}

model DailyLog {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  date       DateTime @default(now())
  weather    String?
  hoursWorked Float?
  crewOnSite String?
  notes      String
  clientVisible Boolean @default(false)
  photos     String?
  // -- Structured fields (P7) ------------------------------------------------
  anticipatedDelays   Boolean @default(false)  // any delays expected today?
  materialDeliveries  Boolean @default(false)  // pickups/deliveries scheduled?
  safetyIncidents     String? // free-text; included in client-visible view
  tradesOnsite        String? // comma-separated or narrative; client-visible
  unplannedTasks      String? // free-text; client-visible
  internalNotes       String? // INTERNAL ONLY — never rendered in client view
  createdAt  DateTime @default(now())
}

model Document {
  id            String   @id @default(cuid())
  projectId     String?
  project       Project? @relation(fields: [projectId], references: [id])
  name          String
  kind          String   // CONTRACT | PLAN | PERMIT | INVOICE | PHOTO | OTHER
  url           String   // local/public URL; empty when stored via object storage (use storageKey) or pending
  storageKey    String?  // object key in S3/R2 when stored in cloud; null for local-disk or pending
  mimeType      String?
  pending       Boolean  @default(false) // true = metadata only, binary not stored yet
  sizeBytes     Int?
  clientVisible Boolean  @default(false)
  uploadedById  String?
  uploadedBy    User?    @relation("UploadedDocuments", fields: [uploadedById], references: [id])
  createdAt     DateTime @default(now())
}

model Thread {
  id         String    @id @default(cuid())
  clientId   String?
  client     Client?   @relation(fields: [clientId], references: [id])
  projectId  String?
  project    Project?  @relation(fields: [projectId], references: [id])
  subject    String
  channel    String    // EMAIL | SMS | IN_APP | CALL_NOTE
  lastAt     DateTime  @default(now())
  unread     Int       @default(0)
  dismissedAt DateTime? // hub-side soft-dismiss; hides from inbox without deleting from Quo/M365
  graphConversationId String? @unique
  quoConversationId String? @unique
  messages   Message[]
}

model Message {
  id         String   @id @default(cuid())
  threadId   String
  thread     Thread   @relation(fields: [threadId], references: [id])
  authorId   String?
  author     User?    @relation("AuthoredMessages", fields: [authorId], references: [id])
  fromName   String   // for external (client) messages without a User
  direction  String   // IN | OUT
  body       String
  channel    String   // EMAIL | SMS | IN_APP | CALL_NOTE
  sentAt     DateTime @default(now())
  graphMessageId String? @unique
  quoMessageId   String? @unique
}

model Estimate {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id])
  authorId   String
  author     User     @relation("EstimateAuthor", fields: [authorId], references: [id])
  number     String   @unique
  title      String
  status     String   @default("DRAFT") // DRAFT | SENT | ACCEPTED | DECLINED
  subtotalCents Int   @default(0)
  taxCents   Int      @default(0)
  totalCents Int      @default(0)
  notes      String?
  lineItems  EstimateLine[]
  contracts  Contract[]
  changeOrders ChangeOrder[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model EstimateLine {
  id          String  @id @default(cuid())
  estimateId  String
  estimate    Estimate @relation(fields: [estimateId], references: [id])
  description String
  quantity    Float    @default(1)
  unitCents   Int      @default(0)
  totalCents  Int      @default(0)
  category    String?
}

model Contract {
  id            String    @id @default(cuid())
  number        String    @unique
  version       Int       @default(1)
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id])
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id])
  estimateId    String?
  estimate      Estimate? @relation(fields: [estimateId], references: [id])
  authorId      String
  author        User      @relation("ContractAuthor", fields: [authorId], references: [id])
  title         String
  status        String    @default("DRAFT") // DRAFT | SENT | SIGNED | VOID
  subtotalCents Int       @default(0)
  taxCents      Int       @default(0)
  totalCents    Int       @default(0)
  depositCents  Int       @default(0)
  terms         String?
  sentAt        DateTime?
  signedAt      DateTime?
  signedByName  String?
  qbInvoiceId   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ChangeOrder {
  id            String    @id @default(cuid())
  number        String    @unique
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id])
  estimateId    String?
  estimate      Estimate? @relation(fields: [estimateId], references: [id])
  createdById   String
  createdBy     User      @relation("ChangeOrderAuthor", fields: [createdById], references: [id])
  title         String
  description   String?
  status        String    @default("DRAFT") // DRAFT | SENT | APPROVED | DECLINED (validated in changeOrderService)
  amountCents   Int       @default(0) // signed: positive adds scope, negative is a credit
  clientVisible Boolean   @default(false)
  sentAt        DateTime?
  decidedAt     DateTime?
  decidedByName String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model TimeEntry {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id])
  costCode     String
  clockIn      DateTime  @default(now())
  clockOut     DateTime?
  hours        Float?
  approved     Boolean   @default(false)
  approvedById String?
  approvedBy   User?     @relation("TimeEntryApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  qbReady      Boolean   @default(false)
  qbTimeActivityId String?
  qbSyncedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model QBOToken {
  id           String   @id @default("global")
  accessToken  String
  refreshToken String
  tokenType    String
  expiresAt    DateTime
  realmId      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Department {
  id       String  @id @default(cuid())
  name     String  @unique
  leaderId String?
}

model SettingAudit {
  id     String   @id @default(cuid())
  key    String
  action String
  userId String
  ts     DateTime @default(now())
}

model AuditLog {
  id      String   @id @default(cuid())
  actorId String
  action  String
  target  String
  ts      DateTime @default(now())
}

model UserNotificationPref {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation(fields: [userId], references: [id])
  event  String  // DAILY_LOG | SELECTION_OVERDUE | CONTRACT_SIGNED | DEPOSIT_PAID | TIME_NEEDS_APPROVAL
  email  Boolean @default(false)
  sms    Boolean @default(false)
  @@unique([userId, event])
}

model M365Config {
  id           String    @id @default("singleton")
  tenantId     String?
  clientId     String?
  clientSecret String?   // TODO: encrypt at rest once an encryption helper exists
  mailbox      String?
  lastSyncAt   DateTime?
  lastSyncOk   Boolean?
  lastSyncMsg  String?
  updatedAt    DateTime  @updatedAt
  sharePointSiteUrl String @default("")
  sharePointSiteId  String @default("")
}

model QuoConfig {
  id               String    @id @default("singleton")
  apiKey           String?   // TODO: encrypt at rest (no encryption helper in codebase)
  defaultPhoneNumberId   String?
  defaultPhoneNumberName String?
  apiBase          String?   // optional override; defaults to the standard Quo API base
  lastSyncAt       DateTime?
  lastSyncOk       Boolean?
  lastSyncMsg      String?
  updatedAt        DateTime  @updatedAt
}

model HenleyTasksConfig {
  id             String    @id @default("singleton")
  apiBaseUrl     String    @default("https://tasks.henleycontracting.com/api")
  apiKey         String?
  lastTestAt     DateTime?
  lastTestOk     Boolean?
  lastTestResult String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// --- External v1 API: per-consumer keys, audit trail, and call log -------
// These power the /api/v1 surface. The full key is never stored â€” only its
// sha256 hash (unique) plus the first 8 chars for masked display.
model ScheduleTask {
  id                String         @id @default(cuid())
  projectId         String
  project           Project        @relation(fields: [projectId], references: [id])
  name              String
  startDate         DateTime
  endDate           DateTime
  baselineStartDate DateTime?
  baselineEndDate   DateTime?
  progress          Float          @default(0)  // 0.0–1.0
  assigneeId        String?
  assignee          User?          @relation("ScheduleTaskAssignee", fields: [assigneeId], references: [id])
  dependsOnId       String?
  dependsOn         ScheduleTask?  @relation("TaskDependency", fields: [dependsOnId], references: [id])
  dependents        ScheduleTask[] @relation("TaskDependency")
  order             Int            @default(0)
  sourceTemplateId  String?        // set when created from a template (idempotency)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model ApiKey {
  id          String        @id @default(cuid())
  name        String        // human-readable, e.g. "Henley Tasks production"
  hashPrefix  String        // first 8 chars of the key, for masked display
  hash        String        @unique // sha256 of the full key
  scopes      String        // comma-separated scope strings
  createdById String
  createdBy   User          @relation("ApiKeyCreator", fields: [createdById], references: [id])
  createdAt   DateTime      @default(now())
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  audits      ApiKeyAudit[]
  callLogs    ApiCallLog[]
}

model ApiKeyAudit {
  id       String   @id @default(cuid())
  apiKeyId String?
  apiKey   ApiKey?  @relation(fields: [apiKeyId], references: [id])
  action   String   // created | rotated | revoked | scope_changed
  actorId  String
  actor    User     @relation("ApiKeyAudit", fields: [actorId], references: [id])
  ts       DateTime @default(now())
  detail   String?  // JSON string for extra context
}

model ApiCallLog {
  id             String   @id @default(cuid())
  apiKeyId       String?
  apiKey         ApiKey?  @relation(fields: [apiKeyId], references: [id])
  method         String   // GET | POST | PATCH | DELETE
  path           String
  status         Int
  scopeUsed      String?
  idempotencyKey String?
  durationMs     Int
  ts             DateTime @default(now())

  @@index([apiKeyId, ts])
  @@index([ts])
}

// ─── Warranty ─────────────────────────────────────────────────────────────────
// Tracks deficiency items for projects in WARRANTY status.
// warrantyPhase is a string field on Project validated against WARRANTY_PHASE.

model WarrantyItem {
  id            String    @id @default(cuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id])
  title         String
  description   String?
  status        String    @default("open")  // open | resolved
  reportedAt    DateTime  @default(now())
  resolvedAt    DateTime?
  clientVisible Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ─── Job Templates ────────────────────────────────────────────────────────────
// Hub-side template: pre-loads schedule skeleton + budget skeleton for a job type.
// Tasks are NOT created here — they stay in Henley Tasks via Door 1.

model JobTemplate {
  id            String                 @id @default(cuid())
  name          String
  jobType       String                 // validated against JOB_TYPE in src/lib/taxonomy.ts
  scheduleItems TemplateScheduleItem[]
  budgetItems   TemplateBudgetItem[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
}

model TemplateScheduleItem {
  id              String      @id @default(cuid())
  templateId      String
  template        JobTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name            String
  offsetStartDays Int         @default(0)  // days from project.startDate
  durationDays    Int         @default(1)
  order           Int         @default(0)
}

model TemplateBudgetItem {
  id          String      @id @default(cuid())
  templateId  String
  template    JobTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  category    String
  budgetCents Int         @default(0)
}

// ─── Vendors / Subcontractors ─────────────────────────────────────────────────
// Mirrors JobTread's vendor data. Tracks W-9 on file and COI insurance expiry
// for compliance. Import via scripts/import-vendors.ts from JobTread export.

model Vendor {
  id           String    @id @default(cuid())
  name         String
  trade        String?   // validated against VENDOR_TRADE in src/lib/taxonomy.ts
  type         String?   // validated against VENDOR_TYPE in src/lib/taxonomy.ts (Subcontractor | Supplier | ...)
  email        String?
  officePhone  String?
  fax          String?
  division     String?   // validated against DIVISION in src/lib/taxonomy.ts
  w9OnFile     Boolean   @default(false)
  coiExpiresAt DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([name])
  @@index([coiExpiresAt])
}

// --- CRM Activities -----------------------------------------------------------
// Tracks notes / calls / meetings logged against a client or a deal (project).
// Either clientId or projectId (or both) must be set -- enforced in the action.

model CrmActivity {
  id         String   @id @default(cuid())
  type       String   // NOTE | CALL | MEETING
  body       String
  occurredAt DateTime @default(now())
  authorId   String
  author     User     @relation("CrmActivityAuthor", fields: [authorId], references: [id])
  clientId   String?
  client     Client?  @relation(fields: [clientId], references: [id])
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id])
  createdAt  DateTime @default(now())

  @@index([clientId, occurredAt])
  @@index([projectId, occurredAt])
}