generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite has no enums; role/status fields are validated in code (see src/lib/roles.ts).

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  passwordHash String
  role        String   // CEO | OFFICE | FIELD | SUB | CLIENT
  focusArea   String?  // e.g. "Sales", "Production", "Design"
  phone       String?
  avatarUrl   String?
  clientId    String?  // if role=CLIENT, link to the Client record they own
  client      Client?  @relation("ClientUsers", fields: [clientId], references: [id])
  qbEmployeeId String?
  department  String?
  reportsToId String?
  reportsTo   User?    @relation("ReportsTo", fields: [reportsToId], references: [id])
  reports     User[]   @relation("ReportsTo")
  active      Boolean  @default(true)
  notificationPrefs UserNotificationPref[]
  assignedProjects ProjectAssignment[]
  authoredLogs DailyLog[]
  authoredMessages Message[] @relation("AuthoredMessages")
  createdEstimates Estimate[] @relation("EstimateAuthor")
  timeEntries TimeEntry[]
  approvedTimeEntries TimeEntry[] @relation("TimeEntryApprover")
  uploadedDocuments Document[] @relation("UploadedDocuments")
  authoredContracts Contract[] @relation("ContractAuthor")
  createdAt   DateTime @default(now())
}

model Client {
  id           String    @id @default(cuid())
  name         String
  primaryEmail String?
  primaryPhone String?
  address      String?
  city         String?
  state        String?
  zip          String?
  stage        String    @default("LEAD") // LEAD | QUALIFIED | PROPOSAL | WON | LOST | ACTIVE | PAST
  source       String?
  notes        String?
  qbCustomerId String?
  users        User[]    @relation("ClientUsers")
  projects     Project[]
  threads      Thread[]
  estimates    Estimate[]
  contracts    Contract[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Project {
  id           String    @id @default(cuid())
  clientId     String
  client       Client    @relation(fields: [clientId], references: [id])
  name         String
  address      String?
  city         String?
  projectType  String?   // Custom Home | Addition | Renovation | Kitchen | Garage | ADU | Misc Small Jobs | Handyman Services | Warranty
  status       String    @default("PLANNING") // PLANNING | DESIGN | PERMITTING | IN_PROGRESS | FINISHING | WARRANTY | CLOSING | ON_HOLD | COMPLETE
  currentPhase String?   // free-text operational phase (e.g. "Permitting / Design Refresh", "Finishings 80%")
  nextStep     String?   // free-text next-action description from the operational tracker
  team         String?   // comma-separated names of PMs / owners (free-text)
  startDate    DateTime?
  actualStart  DateTime?
  targetEnd    DateTime?
  actualEnd    DateTime?
  budgetCents  Int       @default(0)
  contractCents Int      @default(0)
  description  String?
  milestones   Milestone[]
  dailyLogs    DailyLog[]
  budgetItems  BudgetItem[]
  documents    Document[]
  threads      Thread[]
  selections   Selection[]
  assignments  ProjectAssignment[]
  timeEntries  TimeEntry[]
  contracts    Contract[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ProjectAssignment {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   // PM | LEAD | CREW | SUB | DESIGNER
  project   Project  @relation(fields: [projectId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  @@unique([projectId, userId])
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  title       String
  description String?
  dueDate     DateTime?
  status      String    @default("PENDING") // PENDING | IN_PROGRESS | DONE | BLOCKED
  clientVisible Boolean @default(true)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
}

model Selection {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  category    String   // e.g. "Cabinets", "Flooring"
  option      String
  priceCents  Int      @default(0)
  status      String   @default("PROPOSED") // PROPOSED | APPROVED | REJECTED
  decidedAt   DateTime?
  notes       String?
}

model BudgetItem {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id])
  category     String   // Demo, Framing, Plumbing, etc.
  description  String
  estimateCents Int     @default(0)
  actualCents   Int     @default(0)
  vendor       String?
  createdAt    DateTime @default(now())
}

model DailyLog {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  date       DateTime @default(now())
  weather    String?
  hoursWorked Float?
  crewOnSite String?
  notes      String
  clientVisible Boolean @default(false)
  photos     String?
  createdAt  DateTime @default(now())
}

model Document {
  id            String   @id @default(cuid())
  projectId     String?
  project       Project? @relation(fields: [projectId], references: [id])
  name          String
  kind          String   // CONTRACT | PLAN | PERMIT | INVOICE | PHOTO | OTHER
  url           String
  sizeBytes     Int?
  clientVisible Boolean  @default(false)
  uploadedById  String?
  uploadedBy    User?    @relation("UploadedDocuments", fields: [uploadedById], references: [id])
  createdAt     DateTime @default(now())
}

model Thread {
  id         String    @id @default(cuid())
  clientId   String?
  client     Client?   @relation(fields: [clientId], references: [id])
  projectId  String?
  project    Project?  @relation(fields: [projectId], references: [id])
  subject    String
  channel    String    // EMAIL | SMS | IN_APP | CALL_NOTE
  lastAt     DateTime  @default(now())
  unread     Int       @default(0)
  graphConversationId String? @unique
  quoThreadKey String? @unique
  messages   Message[]
}

model Message {
  id         String   @id @default(cuid())
  threadId   String
  thread     Thread   @relation(fields: [threadId], references: [id])
  authorId   String?
  author     User?    @relation("AuthoredMessages", fields: [authorId], references: [id])
  fromName   String   // for external (client) messages without a User
  direction  String   // IN | OUT
  body       String
  channel    String   // EMAIL | SMS | IN_APP | CALL_NOTE
  sentAt     DateTime @default(now())
  graphMessageId String? @unique
  quoMessageId   String? @unique
}

model Estimate {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id])
  authorId   String
  author     User     @relation("EstimateAuthor", fields: [authorId], references: [id])
  number     String   @unique
  title      String
  status     String   @default("DRAFT") // DRAFT | SENT | ACCEPTED | DECLINED
  subtotalCents Int   @default(0)
  taxCents   Int      @default(0)
  totalCents Int      @default(0)
  notes      String?
  lineItems  EstimateLine[]
  contracts  Contract[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model EstimateLine {
  id          String  @id @default(cuid())
  estimateId  String
  estimate    Estimate @relation(fields: [estimateId], references: [id])
  description String
  quantity    Float    @default(1)
  unitCents   Int      @default(0)
  totalCents  Int      @default(0)
  category    String?
}

model Contract {
  id            String    @id @default(cuid())
  number        String    @unique
  version       Int       @default(1)
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id])
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id])
  estimateId    String?
  estimate      Estimate? @relation(fields: [estimateId], references: [id])
  authorId      String
  author        User      @relation("ContractAuthor", fields: [authorId], references: [id])
  title         String
  status        String    @default("DRAFT") // DRAFT | SENT | SIGNED | VOID
  subtotalCents Int       @default(0)
  taxCents      Int       @default(0)
  totalCents    Int       @default(0)
  depositCents  Int       @default(0)
  terms         String?
  sentAt        DateTime?
  signedAt      DateTime?
  signedByName  String?
  qbInvoiceId   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model TimeEntry {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id])
  costCode     String
  clockIn      DateTime  @default(now())
  clockOut     DateTime?
  hours        Float?
  approved     Boolean   @default(false)
  approvedById String?
  approvedBy   User?     @relation("TimeEntryApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  qbReady      Boolean   @default(false)
  qbTimeActivityId String?
  qbSyncedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model QBOToken {
  id           String   @id @default("global")
  accessToken  String
  refreshToken String
  tokenType    String
  expiresAt    DateTime
  realmId      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Department {
  id       String  @id @default(cuid())
  name     String  @unique
  leaderId String?
}

model SettingAudit {
  id     String   @id @default(cuid())
  key    String
  action String
  userId String
  ts     DateTime @default(now())
}

model AuditLog {
  id      String   @id @default(cuid())
  actorId String
  action  String
  target  String
  ts      DateTime @default(now())
}

model UserNotificationPref {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation(fields: [userId], references: [id])
  event  String  // DAILY_LOG | SELECTION_OVERDUE | CONTRACT_SIGNED | DEPOSIT_PAID | TIME_NEEDS_APPROVAL
  email  Boolean @default(false)
  sms    Boolean @default(false)
  @@unique([userId, event])
}

model M365Config {
  id           String    @id @default("singleton")
  tenantId     String?
  clientId     String?
  clientSecret String?   // TODO: encrypt at rest once an encryption helper exists
  mailbox      String?
  lastSyncAt   DateTime?
  lastSyncOk   Boolean?
  lastSyncMsg  String?
  updatedAt    DateTime  @updatedAt
}

model QuoConfig {
  id           String    @id @default("singleton")
  apiKey       String?
  baseUrl      String?   // Quo REST API base, e.g. https://api.quo.com/v1
  inboxNumber  String?   // the Henley inbox phone these messages belong to
  lastSyncAt   DateTime?
  lastSyncOk   Boolean?
  lastSyncMsg  String?
  updatedAt    DateTime  @updatedAt
}
