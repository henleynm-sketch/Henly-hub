# Database
# SQLite for dev. Swap to a Postgres URL for production (also change provider in prisma/schema.prisma).
DATABASE_URL="file:./dev.db"

# Auth.js v5
# Generate with: openssl rand -hex 32
AUTH_SECRET="replace-with-openssl-rand-hex-32"

# Public base URL. Set automatically by .devcontainer/setup.sh in Codespaces.
AUTH_URL="http://localhost:3000"

# Required when running behind a proxy (Codespaces, Vercel, Render, etc.)
AUTH_TRUST_HOST="true"

