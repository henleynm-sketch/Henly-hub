# External API key for Henley Tasks projects feed (Door 1)
HUB_TASKS_API_KEY=""

# Worksite task API (Door 2)
WORKSITE_API_URL="https://tasks.henleycontracting.com/api/api.php"
WORKSITE_API_KEY=""

# Microsoft 365 shared-mailbox sync (app registration by IT)
