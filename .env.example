# ─────────────────────────────────────────────────────────────────────────────
# Henley Hub — environment setup
#
# Env lives in TWO files (monorepo layout). Neither is ever committed —
# both are gitignored. This file is the safe-to-commit template.
#
#   1. Root .env          → auth + app settings (this file's contents)
#                           copy:  cp .env.example .env
#   2. packages/db/.env   → DATABASE_URL only (Prisma reads it there)
#                           copy:  cp packages/db/.env.example packages/db/.env
#
# Fill in real values after copying. Every `npm run ...` script loads the
# root .env via dotenv-cli; Prisma CLI commands pick up packages/db/.env.
# On the production VPS the same two files exist at the same paths.
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth.js v5 (required) ────────────────────────────────────────────────────
# Session-signing secret. Generate a fresh one per environment with:
#   openssl rand -hex 32
AUTH_SECRET="replace-with-openssl-rand-hex-32"

# Public base URL of the app. Local dev = http://localhost:3000,
# production = the real site URL (https://...).
AUTH_URL="http://localhost:3000"

# Required when the app runs behind a proxy (VPS + nginx, Codespaces, etc.).
AUTH_TRUST_HOST="true"

# ── Henley Tasks integration (optional) ──────────────────────────────────────
# API key for the read-only projects feed exposed to tasks.henleycontracting.com.
# Leave empty to disable the feed.
HUB_TASKS_API_KEY=""

# Push integration (Hub → Henley Tasks). The real key is stored in the DB
# (HenleyTasksConfig); these are fallback-only for fresh installs.
HENLEY_TASKS_API_KEY=""
HENLEY_TASKS_API_URL=""

# ── QuickBooks Online (optional — leave blank unless wiring QBO) ─────────────
# From the Intuit developer app registration. QB_ENV is "sandbox" or "production".
QB_CLIENT_ID=""
QB_CLIENT_SECRET=""
QB_REDIRECT_URI=""
QB_ENV="sandbox"

# ── Object storage for documents (optional, S3-compatible: AWS S3 / R2) ──────
# Leave unset to fall back to local-disk storage (public/uploads) in dev.
# STORAGE_ENDPOINT only for R2/MinIO (https://<accountid>.r2.cloudflarestorage.com);
# omit for plain AWS S3.
# STORAGE_ENDPOINT=""
# STORAGE_REGION="auto"
# STORAGE_BUCKET=""
# STORAGE_ACCESS_KEY_ID=""
# STORAGE_SECRET_ACCESS_KEY=""

# ── Microsoft 365 shared-mailbox sync (optional, app registration by IT  ) ─────
M365_TENANT_ID=""
M365_CLIENT_ID=""
M365_CLIENT_SECRET=""
M365_MAILBOX=""
