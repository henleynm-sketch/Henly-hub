{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "prisma generate --schema prisma/schema.prisma",
    "push": "node scripts/load-env.cjs prisma db push --schema prisma/schema.prisma",
    "seed": "node scripts/load-env.cjs tsx prisma/seed.ts",
    "studio": "node scripts/load-env.cjs prisma studio --schema prisma/schema.prisma",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "^22.9.0",
    "dotenv": "^16.4.5",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
