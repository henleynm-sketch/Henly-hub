{
  "name": "@repo/db",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "db:seed:quo": "dotenv -e ../../.env -- tsx prisma/seed-quo-messages.ts",
    "db:seed:real": "dotenv -e ../../.env -- tsx prisma/seed-real-data.ts",
    "db:seed:bt": "dotenv -e ../../.env -- tsx prisma/seed-bt.ts",
    "db:reset": "dotenv -e ../../.env -- prisma db push --force-reset && npm run db:seed",
    "migrate:pg": "prisma generate --schema prisma/schema.sqlite.prisma && dotenv -e ../../.env -- tsx scripts/migrate-sqlite-to-pg.ts"
  },
  "prisma": {
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "dotenv-cli": "^7.4.2",
    "bcryptjs": "^2.4.3",
    "@types/bcryptjs": "^2.4.6",
    "xlsx": "^0.18.5"
  }
}
