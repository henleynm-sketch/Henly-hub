# packages/db/.env — the ONLY place DATABASE_URL lives. Never commit the real file.
# Copy this to packages/db/.env and paste your Postgres connection string.
#
# Production/dev DB is Neon Postgres: dashboard → your project → Connect →
# copy the pooled connection string (postgresql://user:password@host/db?sslmode=require).
# Local Postgres works too: postgresql://postgres:postgres@localhost:5432/henley_hub
#
# NEVER run `npm run db:reset` against a database with real data.
DATABASE_URL="postgresql://user:password@host.example.neon.tech/neondb?sslmode=require"
